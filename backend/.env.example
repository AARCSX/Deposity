# ============================================================
# Deposity Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# --- Server ---
PORT=8080

# --- Database (Neon PostgreSQL) ---
# Paste your Neon connection pooling string below.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- CORS ---
# Comma-separated list of allowed origins. Use * for local dev.
CORS_ORIGINS=http://localhost:3000

# --- AARCSX Identity ---
# Endpoint URL and JWKS URI for user authentication.
IDENTITY_URL=https://<supabase-project-id>.supabase.co/functions/v1
IDENTITY_JWKS=https://<supabase-project-id>.supabase.co/functions/v1/oauth-jwks
IDENTITY_ANON_KEY=your-supabase-anon-key-here

# --- Brevo Transactional Email ---
# Brevo REST API v3 Key and sender email address.
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_DEPOSITY_WELCOME_FROM=welcome@yourdomain.com

# --- Redis Cache & Blacklist ---
# Redis Connection URL (local docker dev uses redis://redis:6379, production uses upstash rediss://...)
REDIS_URL=redis://redis:6379
